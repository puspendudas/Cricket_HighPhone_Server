        {
          "name": "Get All Match Bets",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/match-bets?skip=0&count=20&status=PENDING",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "match-bets"],
              "query": [
                {
                  "key": "skip",
                  "value": "0"
                },
                {
                  "key": "count",
                  "value": "20"
                },
                {
                  "key": "status",
                  "value": "PENDING"
                }
              ]
            },
            "description": "Get all match bets with pagination and filters"
          }
        },
