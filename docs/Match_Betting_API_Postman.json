{
  "info": {
    "name": "Cricket Match Betting API",
    "description": "Complete API collection for cricket match betting system with BOOKMAKER and FANCY bet types",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Match Betting",
      "item": [
        {
          "name": "Create BOOKMAKER Bet (Back)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{user_id}}\",\n  \"match_id\": \"{{match_id}}\",\n  \"bet_type\": \"BOOKMAKER\",\n  \"selection\": \"Back\",\n  \"selection_id\": 47972,\n  \"odds_value\": \"1.85\",\n  \"odds_rate\": \"85\",\n  \"stake_amount\": 100,\n  \"team_name\": \"India\",\n  \"game_id\": \"32540047\",\n  \"event_id\": \"32540047\",\n  \"min_stake\": 10,\n  \"max_stake\": 10000,\n  \"is_active\": true,\n  \"is_enabled\": true,\n  \"bet_metadata\": {\n    \"market_type\": \"match_odds\",\n    \"runner_type\": \"team\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/match-bets/create",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "match-bets", "create"]
            },
            "description": "Create a BOOKMAKER Back bet on a team to win"
          }
        },
