{
    "watch": [
        "src",
        ".env"
    ],
    "delay": 1500,
    "watchOptions": {
        "usePolling": true,
        "interval": 1000
    },
    "ext": "js,ts,json",
    "ignore": [
        "src/logs/*",
        "src/**/*.{spec,test}.ts"
    ],
    "exec": "ts-node -r tsconfig-paths/register --transpile-only src/server.ts"
}